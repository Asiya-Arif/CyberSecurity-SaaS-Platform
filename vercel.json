{
  "builds": [
    {
      "src": "app/api/chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "app/api/chat.js"
    },
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ]
}
